# PostgreSQL local — use o banco delivery_os (pgAdmin / PostgreSQL 18)
#
# Opção A — Docker (npm run db:setup):
#   docker compose up -d
#   DATABASE_URL=postgresql://delivery:delivery@localhost:5432/delivery_os
#
# Opção B — PostgreSQL 18 instalado no Windows (como no pgAdmin):
#   Crie o banco "delivery_os" e ajuste usuário/senha abaixo.
#   Senha com @ ou # precisa ser codificada na URL (@ → %40)
#   DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/delivery_os
#
DATABASE_URL=postgresql://delivery:delivery@localhost:5432/delivery_os

# Sessão (troque em produção)
SESSION_SECRET=change-me-in-production-min-32-chars

# URL pública do app (links de rastreio, WhatsApp, retorno de pagamento)
PUBLIC_APP_URL=http://localhost:3000

# Mapbox (mapa live, rastreio cliente)
VITE_MAPBOX_TOKEN=pk.seu_token_mapbox_aqui

# WhatsApp — Evolution API (opcional; sem config = modo demo nos logs)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=

# Pagamentos — mock | mercadopago | stripe | asaas
PAYMENT_PROVIDER=mock

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Stripe (Pix + cartão BRL)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Asaas (sandbox: ASAAS_SANDBOX=true ou ASAAS_API_URL=https://api-sandbox.asaas.com/v3)
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SANDBOX=true
ASAAS_API_URL=

# Telefone fallback para alertas SLA (se perfil do gerente não tiver phone)
WHATSAPP_MANAGER_PHONE=

# Cron iFood server-side — POST/GET /api/cron/ifood-poll (header x-cron-secret ou Bearer)
IFOOD_CRON_SECRET=

# Web Push (PWA entregador) — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@seudominio.com.br

# SSE operacional — intervalo em ms (padrão 5000; mínimo 2000)
OPS_SSE_INTERVAL_MS=5000

# =============================================================================
# PRODUÇÃO — checklist: npm run production:check
# =============================================================================
# NODE_ENV=production
#
# Obrigatório em produção:
#   DATABASE_URL          Postgres gerenciado (backup diário)
#   SESSION_SECRET        32+ chars aleatórios (openssl rand -hex 32)
#   PUBLIC_APP_URL        https://app.seudominio.com.br (sem barra final)
#   PAYMENT_PROVIDER      mercadopago | stripe | asaas (nunca mock)
#
# Recomendado:
#   VITE_MAPBOX_TOKEN     mapa live + rastreio
#   WHATSAPP_*            Evolution API
#   VAPID_*               push PWA entregador
#   IFOOD_CRON_SECRET     protege POST /api/cron/ifood-poll
#   MERCADOPAGO_WEBHOOK_SECRET / STRIPE_WEBHOOK_SECRET / ASAAS_WEBHOOK_TOKEN
#
# Webhooks públicos (substitua pelo seu domínio):
#   Pagamentos: {PUBLIC_APP_URL}/api/payments/webhook
#   iFood:      {PUBLIC_APP_URL}/api/integrations/ifood/webhook
#   Saúde:      {PUBLIC_APP_URL}/api/health
